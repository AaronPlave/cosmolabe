{
  "name": "spicecraft",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "description": "Web SPICE geometry and 3D mission visualization",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/ apps/",
    "preprocess:displacement": "node scripts/preprocess-displacement.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "lightstreamer-client-web": "^9.2.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
